extends layout
block content
    h1 Egg Create Page
    if (toShow == null)
        h2 No instance to delete
    else
        - let eggid = toShow._id
        - let bird_type = toShow.bird_type
        - let eggcolor = toShow.color
        - let eggsize = toShow.size
        - let actionid = "/resource/egg/" + eggid
        script. 
            let actionid = "#{actionid}"
        div
            div.row
                div(class='eggAttr mr-3') Egg ID is:
                div #{eggid}
            div.row
                div(class='eggAttr mr-3') Bird Type is:
                div #{bird_type}
            div.row
                div(class='eggAttr mr-3') Egg Color is:
                div #{eggcolor}
            div.row
                div(class='eggAttr mr-3') Egg Size is:
                div #{eggsize}

        button(class="btn btn-danger m-2" onclick="deleteOnid()") Delete
        button(class="btn btn-secondary m-2" onclick="cancel()") Cancel

    script.
        function cancel() {
            window.location.href='/egg'
        }

    script.
        function deleteOnid() {
            console.log("starting delete")
            fetch(actionid, {
                method: 'DELETE'
            }).then((resp) => {
                return resp.json();
            }).then((body) => {
                alert("Delete succeded")
                window.location.href='/egg'
            }).catch((error) => {
                alert("Delete failed " + error )
            });
        }