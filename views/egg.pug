extends layout

block content
  h1 Eggs 
  p Logan Zoller eggs class server

  button.btn(class="btn-success mb-2", href="/egg/create") Create New Egg
  
  - let items = results

  div(class="container-fluid")
    div(class="row")
      each item in results
        - let destination = `dispatch("/egg/${item._id}/update")`
        - let detail = `dispatch("/egg/${item._id}")`
        - let Delete = `dispatch("/egg/${item._id}/delete")`
        div(class="row-sm-2", class="m-1")
          | Item: #{item.bird_type} (#{item.color}) is #{item.size}  
          button.btn(class="btn-primary ml-1", onclick=destination) Update
          button.btn(class="btn-info m1-1", onclick=detail) Details
          button.btn(class="btn-danger m1-1", onclick=Delete) Delete

    script.
      function dispatch(path) {
        window.location.href=path
      }